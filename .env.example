# RSS
FEED_URL=https://techcrunch.com/feed/

# AI provider: gemini or ollama
MODEL_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Ollama (optional local fallback)
OLLAMA_MODEL=llama3.1
OLLAMA_URL=http://localhost:11434/api/generate

# LinkedIn session state file generated by save_linkedin_session.py
LINKEDIN_STATE_FILE=linkedin_state.json

# Fallback login when session expires (optional but recommended)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Runtime
HEADLESS=true
LOG_LEVEL=INFO
